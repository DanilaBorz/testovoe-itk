# Сервер
SERVER_PORT=8080

# База данных
DB_HOST=postgres
DB_PORT=5432
DB_USER=wallet_user
DB_PASSWORD=wallet_pass
DB_NAME=wallet_db
DB_SSLMODE=disable

# Переменные для контейнера PostgreSQL.
# Значения совпадают с DB_USER, DB_PASSWORD и DB_NAME.
POSTGRES_USER=wallet_user
POSTGRES_PASSWORD=wallet_pass
POSTGRES_DB=wallet_db

# Пул соединений
DB_MAX_CONNS=50
DB_MIN_CONNS=10

# Логирование
LOG_LEVEL=info
